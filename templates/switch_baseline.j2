! -----------------------------------------------------------
! Baseline config for {{ inventory_hostname }}
! Source of truth: Git. Do not edit on-box.
! -----------------------------------------------------------
hostname {{ hostname }}
!
ip domain-name {{ lab.domain }}
no ip domain-lookup
!
clock timezone {{ lab.timezone_name }} {{ lab.timezone_offset }} 0
!
{% for ntp in lab.ntp_servers %}
ntp server {{ ntp }}
{% endfor %}
!
{% for dns in lab.dns_servers %}
ip name-server {{ dns }}
{% endfor %}
!
! Local user (privilege 15) and enable secret
username {{ ansible_user }} privilege 15 secret {{ ansible_password }}
enable secret {{ ansible_become_password }}
!
! SSH only on vty
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
!
line vty 0 15
 transport input ssh
 login local
!
line con 0
 login local
 logging synchronous
!
! Logging
logging host {{ lab.syslog_host }}
logging trap informational
service timestamps log datetime msec localtime show-timezone
service timestamps debug datetime msec localtime show-timezone
!
! VLANs
{% for v in default_vlans %}
vlan {{ v.id }}
 name {{ v.name }}
!
{% endfor %}
!
! Management SVI
interface Vlan{{ mgmt_vlan }}
 description MGMT
 ip address {{ mgmt_ip }} {{ mgmt_mask }}
 no shutdown
!
ip default-gateway {{ mgmt_gateway }}
!
! Spanning tree
spanning-tree mode rapid-pvst
spanning-tree extend system-id
!
! Access ports
{% for p in access_ports | default([]) %}
interface {{ p.interface }}
 description {{ p.description }}
 switchport mode access
 switchport access vlan {{ p.vlan }}
 spanning-tree portfast
 spanning-tree bpduguard enable
 no shutdown
!
{% endfor %}
!
! Trunk ports
{% for p in trunk_ports | default([]) %}
interface {{ p.interface }}
 description {{ p.description }}
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan {{ p.native_vlan }}
 switchport trunk allowed vlan {{ p.allowed_vlans }}
 no shutdown
!
{% endfor %}
!
end
